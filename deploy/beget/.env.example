# Compose-level parameters only — NOT Hermes secrets.
#
# Hermes's own secrets (model provider keys, messaging bot tokens, etc.)
# live in /srv/hermes/data/.env on the VPS and are read by the container
# straight from the bind-mounted /opt/data volume. They do NOT belong in
# this file and must never be added here.
#
# Copy this file to deploy/beget/.env on the VPS (chmod 600, gitignored)
# and adjust as needed.

# Set automatically by deploy.sh / the manual build commands in README.md —
# only needed here if you want to pin a build outside of deploy.sh.
# HERMES_GIT_SHA=
# HERMES_IMAGE_TAG=

# UID/GID the container's `hermes` user runs as. Must own /srv/hermes/data
# (stage2-hook.sh chowns the volume to these on first boot). Defaults match
# the image's built-in `hermes` user — only change if /srv/hermes/data is
# already owned by a different host UID/GID.
HERMES_UID=10000
HERMES_GID=10000

# Dashboard stays OFF until Этап 10 (SSH-tunnel-only access, auth configured).
# Do not set to 1 without also setting a HERMES_DASHBOARD_* auth provider —
# see website/docs/user-guide/docker.md#running-the-dashboard.
HERMES_DASHBOARD=0
